{
  "name": "dagent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:graph:all": "powershell -ExecutionPolicy Bypass -File scripts/start-weave-graph-all.ps1",
    "dev:graph:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-weave-graph-all.ps1",
    "dev:graph:logs": "powershell -ExecutionPolicy Bypass -Command \"Set-Location apps/weave-graph-server; if(Test-Path .run.log){Get-Content .run.log -Wait -Tail 80}else{Write-Host '.run.log not found, run dev:graph:all first'}\"",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "verify:step-gate": "node scripts/verify-step-gate.mjs",
    "verify:dag-matrix": "node scripts/verify-dag-matrix.mjs",
    "verify:graph-recovery": "tsx scripts/verify-graph-recovery.ts",
    "verify:rpc-pending": "tsx scripts/verify-rpc-pending.ts",
    "verify:gateway-reconnect": "pnpm --filter weave-graph-server verify:gateway-reconnect",
    "verify:p0": "pnpm build && pnpm verify:step-gate && pnpm verify:dag-matrix"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "flatted": "^3.4.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "openai": "^4.86.1",
    "react": "^19.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
